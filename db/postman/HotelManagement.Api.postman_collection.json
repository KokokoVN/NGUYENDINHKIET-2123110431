{
  "info": {
    "_postman_id": "3e5232bd-408f-46f0-a22f-98be2473f7c7",
    "name": "HotelManagement API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5066" },
    { "key": "accessToken", "value": "" },
    { "key": "hotelId", "value": "1" },
    { "key": "roomTypeId", "value": "1" },
    { "key": "roomId", "value": "1" },
    { "key": "customerId", "value": "1" },
    { "key": "bookingId", "value": "1" },
    { "key": "stayId", "value": "1" },
    { "key": "invoiceId", "value": "1" },
    { "key": "paymentId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "roleId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        { "name": "Me", "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/me" } },
        { "name": "Logout", "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/logout" } }
      ]
    },
    {
      "name": "Core",
      "item": [
        { "name": "Hotels - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/hotels" } },
        { "name": "Hotels - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"hotelName\": \"Khach san Test\",\n  \"address\": \"Q1\",\n  \"phone\": \"0900000000\",\n  \"email\": \"test@hotel.local\",\n  \"isActive\": true\n}" }, "url": "{{baseUrl}}/api/hotels" } },
        { "name": "RoomTypes - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/roomtypes?hotelId={{hotelId}}" } },
        { "name": "RoomTypes - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"hotelId\": {{hotelId}},\n  \"roomTypeName\": \"Suite\",\n  \"capacity\": 2,\n  \"baseRate\": 1200000,\n  \"description\": \"Suite\",\n  \"isActive\": true\n}" }, "url": "{{baseUrl}}/api/roomtypes" } },
        { "name": "Rooms - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/rooms" } },
        { "name": "Rooms - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"hotelId\": {{hotelId}},\n  \"roomTypeId\": {{roomTypeId}},\n  \"roomNumber\": \"301\",\n  \"floor\": \"3\",\n  \"statusCode\": \"VACANT\"\n}" }, "url": "{{baseUrl}}/api/rooms" } },
        { "name": "Customers - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/customers" } },
        { "name": "Customers - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"customerType\": \"INDIVIDUAL\",\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"0900111222\",\n  \"email\": \"a@email.com\"\n}" }, "url": "{{baseUrl}}/api/customers" } },
        { "name": "Bookings - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/bookings" } },
        { "name": "Bookings - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"roomId\": {{roomId}},\n  \"customerId\": {{customerId}},\n  \"checkInDate\": \"2026-05-10\",\n  \"checkOutDate\": \"2026-05-12\",\n  \"adults\": 2,\n  \"children\": 0\n}" }, "url": "{{baseUrl}}/api/bookings" } },
        { "name": "Bookings - CheckIn", "request": { "method": "PUT", "url": "{{baseUrl}}/api/bookings/{{bookingId}}/check-in" } },
        { "name": "Bookings - CheckOut", "request": { "method": "PUT", "url": "{{baseUrl}}/api/bookings/{{bookingId}}/check-out" } },
        { "name": "Invoices - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/invoices" } },
        { "name": "Invoices - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"bookingId\": {{bookingId}},\n  \"paymentMethod\": \"CASH\",\n  \"note\": \"invoice\"\n}" }, "url": "{{baseUrl}}/api/invoices" } }
      ]
    },
    {
      "name": "Other",
      "item": [
        { "name": "Stays - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/stays" } },
        { "name": "ServiceOrders - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/serviceorders?stayId={{stayId}}" } },
        { "name": "ServiceOrders - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"stayId\": {{stayId}},\n  \"serviceCode\": \"BREAKFAST\",\n  \"description\": \"Breakfast\",\n  \"quantity\": 2,\n  \"unitPrice\": 80000\n}" }, "url": "{{baseUrl}}/api/serviceorders" } },
        { "name": "Payments - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/payments" } },
        { "name": "Payments - POST", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"invoiceId\": {{invoiceId}},\n  \"amount\": 100000,\n  \"methodCode\": \"CASH\",\n  \"note\": \"payment\"\n}" }, "url": "{{baseUrl}}/api/payments" } },
        { "name": "Guests - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/guests" } },
        { "name": "HousekeepingTasks - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/housekeepingtasks" } },
        { "name": "MaintenanceTickets - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/maintenancetickets" } },
        { "name": "HotelServices - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/hotelservices" } },
        { "name": "Reports - Dashboard", "request": { "method": "GET", "url": "{{baseUrl}}/api/reports/dashboard" } },
        { "name": "AuditLogs - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/auditlogs?action=API_&take=100" } },
        { "name": "Users - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/users" } },
        { "name": "Roles - GET", "request": { "method": "GET", "url": "{{baseUrl}}/api/roles" } }
      ]
    }
  ]
}
